# Inverted gitignore: ignore everything, whitelist what we need.
# Directories must be un-ignored for git to traverse into them.
*
!*/

# Top-level project files
!.gitignore
!flake.nix
!flake.lock
!CMakeLists.txt
!README.md
!ROADMAP.md
!WHY.md
!IRSH.md
!IRIS.md
!IRISH.md
!LICENSE

# CMake package templates
!cmake/*.in

# Build / output dirs (re-block after top-level rules)
build/
build-*/
result
result-*
.direnv/

# Headers
!include/**/*.hpp
!include/**/*.h

# SDK (MIT)
!sdk/**/*.hpp
!sdk/**/*.h
!sdk/**/*.py
!sdk/LICENSE

# Sources
!src/**/*.cpp
!src/**/*.hpp
!src/**/*.h
!src/**/CMakeLists.txt

# Docs
!docs/**/*.md

# Tests
!tests/**/*.cpp
!tests/**/*.hpp
!tests/**/*.h
!tests/**/CMakeLists.txt
